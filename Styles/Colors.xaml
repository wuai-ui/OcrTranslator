<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 主题 Token：亮/暗双色值。所有控件颜色从此处取，消灭硬编码 #FFxxxxxx。 -->

    <ResourceDictionary.ThemeDictionaries>

        <!-- ════════════ 浅色主题 ════════════ -->
        <ResourceDictionary x:Key="Light">
            <!-- 背景 -->
            <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFF5F5F5"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE8E8E8"/>
            <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="SubtleControlBrush" Color="#FFF8F8F8"/>
            <SolidColorBrush x:Key="SubtleBorderBrush" Color="#FFD8D8D8"/>

            <!-- 文本 -->
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF1A1A1A"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF666666"/>
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="#FF999999"/>
            <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FFFFFFFF"/>

            <!-- 语义强调色 -->
            <SolidColorBrush x:Key="AccentBrush" Color="#FF0078D4"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="#FF16A34A"/>
            <SolidColorBrush x:Key="WarningBrush" Color="#FFEA580C"/>
            <SolidColorBrush x:Key="InfoBrush" Color="#FF7B61FF"/>

            <!-- 语义浅底（彩色按钮背景 tint） -->
            <SolidColorBrush x:Key="AccentSubtleBrush" Color="#FFF0F7FF"/>
            <SolidColorBrush x:Key="SuccessSubtleBrush" Color="#FFF0FFF0"/>
            <SolidColorBrush x:Key="WarningSubtleBrush" Color="#FFFFF8F0"/>
            <SolidColorBrush x:Key="InfoSubtleBrush" Color="#FFF8F0FF"/>

            <!-- 语义浅边 -->
            <SolidColorBrush x:Key="AccentSubtleBorderBrush" Color="#FFB8D4E8"/>
            <SolidColorBrush x:Key="SuccessSubtleBorderBrush" Color="#FFB8E8B8"/>
            <SolidColorBrush x:Key="WarningSubtleBorderBrush" Color="#FFE8D4B8"/>
            <SolidColorBrush x:Key="InfoSubtleBorderBrush" Color="#FFD4B8E8"/>
        </ResourceDictionary>

        <!-- ════════════ 深色主题 ════════════ -->
        <ResourceDictionary x:Key="Dark">
            <!-- 背景 -->
            <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF202020"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF2B2B2B"/>
            <SolidColorBrush x:Key="CardBorderBrush" Color="#FF3A3A3A"/>
            <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="#FF2B2B2B"/>
            <SolidColorBrush x:Key="SubtleControlBrush" Color="#FF333333"/>
            <SolidColorBrush x:Key="SubtleBorderBrush" Color="#FF454545"/>

            <!-- 文本 -->
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFC5C5C5"/>
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="#FF8A8A8A"/>
            <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FF000000"/>

            <!-- 语义强调色 -->
            <SolidColorBrush x:Key="AccentBrush" Color="#FF60CDFF"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="#FF6EE7A0"/>
            <SolidColorBrush x:Key="WarningBrush" Color="#FFFFA552"/>
            <SolidColorBrush x:Key="InfoBrush" Color="#FFB5A0FF"/>

            <!-- 语义浅底 -->
            <SolidColorBrush x:Key="AccentSubtleBrush" Color="#FF1A2A3D"/>
            <SolidColorBrush x:Key="SuccessSubtleBrush" Color="#FF1A3326"/>
            <SolidColorBrush x:Key="WarningSubtleBrush" Color="#FF332A1A"/>
            <SolidColorBrush x:Key="InfoSubtleBrush" Color="#FF262038"/>

            <!-- 语义浅边 -->
            <SolidColorBrush x:Key="AccentSubtleBorderBrush" Color="#FF1F3D5A"/>
            <SolidColorBrush x:Key="SuccessSubtleBorderBrush" Color="#FF1F4A30"/>
            <SolidColorBrush x:Key="WarningSubtleBorderBrush" Color="#FF4A3A1F"/>
            <SolidColorBrush x:Key="InfoSubtleBorderBrush" Color="#FF3A2F55"/>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
