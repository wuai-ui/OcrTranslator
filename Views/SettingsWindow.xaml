<Window
    x:Class="OcrTranslator.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="极客 OCR v4 - 控制中心">

    <Grid Background="{ThemeResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <TextBlock Text="控制中心" VerticalAlignment="Center" Margin="12,0,0,0"
                       FontSize="12" FontWeight="Bold" Foreground="{ThemeResource TextPrimaryBrush}"/>
        </Grid>

        <!-- IsSettingsVisible=False：隐藏 NavigationView 内置的底部"设置"齿轮（点击空白） -->
        <NavigationView x:Name="SettingsNav" Grid.Row="1" PaneDisplayMode="Left"
                        IsBackButtonVisible="Collapsed" IsSettingsVisible="False"
                        SelectionChanged="SettingsNav_SelectionChanged"
                        Background="Transparent">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="系统设置" Tag="SystemTab">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE713;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="API 与密钥" Tag="ApiTab">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE72B;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="快捷键" Tag="HotkeyTab">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE765;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="OCR 模式" Tag="OcrModeTab">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8A5;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="字体配置" Tag="FontTab">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8D2;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="关于" Tag="AboutTab">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE946;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <ScrollViewer Padding="24" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- 系统设置（主题 + 自动翻译 + 开机自启） -->
                    <StackPanel x:Name="SystemPanel" Visibility="Visible" Spacing="20">
                        <TextBlock Text="系统设置" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}"/>

                        <StackPanel Spacing="8">
                            <TextBlock Text="外观主题" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <RadioButtons x:Name="ThemeRadio" MaxColumns="3" SelectionChanged="ThemeRadio_SelectionChanged">
                                <RadioButton Content="浅色"/>
                                <RadioButton Content="深色"/>
                                <RadioButton Content="跟随系统"/>
                            </RadioButtons>
                            <TextBlock Text="切换即时生效并记忆。跟随系统时随 Windows 亮/暗自动切换。" FontSize="12" Foreground="{ThemeResource TextTertiaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="翻译行为" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <ToggleSwitch x:Name="AutoTranslateSwitch" Header="OCR 识别后自动翻译" OnContent="开启" OffContent="关闭"/>
                            <TextBlock Text="关闭后，OCR 识别结果不会自动翻译，需手动点击翻译按钮或使用快捷翻译" FontSize="12" Foreground="{ThemeResource TextTertiaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="系统行为" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <ToggleSwitch x:Name="StartupSwitch" Header="开机自动启动" OnContent="开启" OffContent="关闭" Toggled="StartupSwitch_Toggled"/>
                            <TextBlock Text="通过注册表 Run 键实现（键名 GeekOCR_v4，与 v3 隔离），无需管理员权限" FontSize="12" Foreground="{ThemeResource TextTertiaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- API 密钥配置 -->
                    <StackPanel x:Name="ApiPanel" Visibility="Collapsed" Spacing="16">
                        <TextBlock Text="API 密钥与网关配置" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}"/>
                        <Grid ColumnSpacing="16" RowSpacing="16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBox Grid.Row="0" Grid.Column="0" x:Name="OcrApiKeyBox" Header="百度 OCR API Key"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="OcrSecretKeyBox" Header="百度 OCR Secret Key"/>
                            <TextBox Grid.Row="1" Grid.Column="0" x:Name="VoiceApiKeyBox" Header="百度 TTS API Key"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="VoiceSecretKeyBox" Header="百度 TTS Secret Key"/>
                            <TextBox Grid.Row="2" Grid.Column="0" x:Name="TransAppIdBox" Header="翻译 APP ID"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="TransSecretKeyBox" Header="翻译密钥"/>
                        </Grid>
                    </StackPanel>

                    <!-- 快捷键配置 -->
                    <StackPanel x:Name="HotkeyPanel" Visibility="Collapsed" Spacing="16">
                        <TextBlock Text="快捷键配置" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}"/>
                        <Grid ColumnSpacing="16" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="OCR 截图识别" VerticalAlignment="Center" FontSize="14" MinWidth="120" Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <Button x:Name="OcrHotkeyBtn" Grid.Row="0" Grid.Column="1" Content="点击录制快捷键" MinWidth="200" HorizontalAlignment="Left" Padding="12,6" Click="OcrHotkeyBtn_Click"/>
                            <Button Grid.Row="0" Grid.Column="2" Content="恢复默认" Padding="12,6" Click="OcrHotkeyReset_Click"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="快捷翻译" VerticalAlignment="Center" FontSize="14" MinWidth="120" Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <Button x:Name="TranslateHotkeyBtn" Grid.Row="1" Grid.Column="1" Content="点击录制快捷键" MinWidth="200" HorizontalAlignment="Left" Padding="12,6" Click="TranslateHotkeyBtn_Click"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="恢复默认" Padding="12,6" Click="TranslateHotkeyReset_Click"/>
                        </Grid>
                        <TextBlock Text="支持组合键（Ctrl/Shift/Alt + 任意键）或单功能键（F1-F12、PrintScreen 等）。ESC 取消录制，10 秒超时自动停止。保存后生效。" FontSize="12" Foreground="{ThemeResource TextTertiaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- OCR 模式管理 -->
                    <StackPanel x:Name="OcrModePanel" Visibility="Collapsed" Spacing="16">
                        <TextBlock Text="默认 OCR 识别模式" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}"/>
                        <StackPanel Spacing="8">
                            <TextBlock Text="选择 OCR 截图识别时默认使用的识别模式" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}"/>
                            <ComboBox x:Name="DefaultOcrModeComboBox" MinWidth="200" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <TextBlock Text="主界面 OCR 模式管理" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="开关控制哪些 OCR 模式显示在主界面的下拉框中" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}"/>
                        <StackPanel x:Name="OcrModesContainer" Spacing="8"/>
                    </StackPanel>

                    <!-- 字体配置 -->
                    <StackPanel x:Name="FontPanel" Visibility="Collapsed" Spacing="16">
                        <TextBlock Text="字体快捷切换配置" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}"/>
                        <TextBlock Text="开关控制哪些字体显示在主界面的字体选择菜单中" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}"/>
                        <StackPanel x:Name="FontsContainer" Spacing="8"/>
                    </StackPanel>

                    <!-- 关于 -->
                    <StackPanel x:Name="AboutPanel" Visibility="Collapsed" Spacing="16">
                        <TextBlock Text="关于 极客 OCR" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}"/>
                        <TextBlock Text="v4.0 | .NET 10 + WinUI 3 + Windows App SDK 1.7" FontSize="14" Foreground="{ThemeResource TextPrimaryBrush}"/>
                        <TextBlock Text="分层架构（Abstractions / Services / ViewModels / Views）+ Mica 材质 + 三态主题。配置与日志独立于 v3（GeekOCR_v4）。" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                        <HyperlinkButton Content="GitHub 开源主页" NavigateUri="https://github.com/wuai-ui/OcrTranslator"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </NavigationView>

        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="12">
            <Button x:Name="SaveButton" Content="保存并应用" HorizontalAlignment="Right"
                    Background="{ThemeResource AccentBrush}" Foreground="{ThemeResource TextOnAccentBrush}"
                    Width="120" CornerRadius="6" Click="SaveSettings_Click"/>
        </Border>
    </Grid>
</Window>
