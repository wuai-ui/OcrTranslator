<Window
    x:Class="OcrTranslator.Views.LoadingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="识别中">

    <!-- Acrylic 玻璃弹层：背景由 DesktopAcrylicBackdrop 提供（cs 中设置），此处保持透明 -->
    <Grid Padding="0" Background="Transparent">
        <Border
            Background="{ThemeResource CardBackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{ThemeResource CardBorderBrush}"
            BorderThickness="1"
            Padding="32,28,32,24"
            MaxWidth="380"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <StackPanel HorizontalAlignment="Center" Spacing="20" MinWidth="260">

                <!-- 顶部图标区域 -->
                <Grid HorizontalAlignment="Center" Width="64" Height="64">
                    <Ellipse Fill="{ThemeResource AccentSubtleBrush}" Width="64" Height="64"/>
                    <FontIcon Glyph="&#xE8A5;" FontSize="28" Foreground="{ThemeResource AccentBrush}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- 标题 -->
                <TextBlock
                    x:Name="TitleText"
                    Text="正在识别文字"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    HorizontalAlignment="Center"/>

                <!-- 状态描述 -->
                <TextBlock
                    x:Name="StatusText"
                    Text="正在截取屏幕内容，请稍候..."
                    FontSize="13"
                    Foreground="{ThemeResource TextSecondaryBrush}"
                    HorizontalAlignment="Center"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    MaxWidth="280"/>

                <!-- 进度指示器 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <ProgressRing
                        IsActive="True"
                        Width="36"
                        Height="36"
                        Foreground="{ThemeResource AccentBrush}"/>

                    <TextBlock
                        x:Name="StepText"
                        Text="调用云端 OCR 引擎中"
                        FontSize="11"
                        Foreground="{ThemeResource TextTertiaryBrush}"
                        HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 底部提示 -->
                <TextBlock
                    Text="按 ESC 可取消操作"
                    FontSize="11"
                    Foreground="{ThemeResource TextTertiaryBrush}"
                    HorizontalAlignment="Center"
                    Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
